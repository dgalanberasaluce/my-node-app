# .env.example
#
# Copy this file to .env and adjust values for your local setup.
# NEVER commit a .env file with real secrets to source control.
#
# Quick start (all mocks, no Docker needed):
#   cp .env.example .env
#   pnpm run start:mock
#
# With real services (requires docker compose up):
#   cp .env.example .env
#   # Set USE_MOCKS=false and BROKER_TYPE to rabbitmq or kafka
#   pnpm run compose:up
#   pnpm run start:real

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── JWT ───────────────────────────────────────────────────────────────────────
# CHANGE THIS — any long random string works for local dev.
JWT_SECRET=dev-insecure-secret-do-not-use-in-production
JWT_EXPIRES_IN=1h
JWT_ISSUER=my-node-app
JWT_AUDIENCE=my-node-app-users

# ── Mocks ─────────────────────────────────────────────────────────────────────
# true  → all external services (DB, Redis, broker) run in-process; no Docker needed.
# false → real external services required (see docker-compose.yml).
USE_MOCKS=true

# ── SQLite ────────────────────────────────────────────────────────────────────
# :memory: = ephemeral in-process DB (default, great for examples/tests).
# ./data/app.db = persistent file-based DB.
DB_FILE=:memory:

# ── Redis ─────────────────────────────────────────────────────────────────────
# Only used when USE_MOCKS=false.
REDIS_URL=redis://localhost:6379

# ── Message broker ────────────────────────────────────────────────────────────
# Options: mock | rabbitmq | kafka
# 'mock' is always used when USE_MOCKS=true regardless of BROKER_TYPE.
BROKER_TYPE=mock

RABBITMQ_URL=amqp://guest:guest@localhost:5672

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=my-node-app
